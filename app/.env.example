# Data source toggle — build-time. Inlined into the JS bundle.
#
# true  — the app renders from the static mocks in lib/mock-data.ts.
#         No network calls, no Apollo, no backend dependency.
# false — the app reads from the real GraphQL API via Apollo Client.
#         NEVER falls back to mocks on error: the user sees a retry
#         card instead. Must be publicly reachable from the device
#         (localhost will not work from a phone).
EXPO_PUBLIC_USE_MOCKS=false

# GraphQL endpoint — only used when USE_MOCKS=false. For phone testing,
# tunnel the backend with ngrok/cloudflared and paste the HTTPS URL.
EXPO_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:7777/graphql

# The apex domain for the white-label scheme. The app reads the slug
# from a deep link (gymapp://?slug=crossfit-sp) OR from SecureStore.
EXPO_PUBLIC_APP_DOMAIN=gym.app

# ---------------------------------------------------------------------
# Server-only secrets below. These are NOT inlined into the JS bundle
# (no EXPO_PUBLIC_ prefix). Only the Expo/EAS CLI running inside the
# Docker container reads them. Safe to leave blank in local dev.
# ---------------------------------------------------------------------

# Expo personal access token — used by the CLI for any authenticated
# operation (eas update, eas build, eas submit). Serving the dev
# bundle via `expo start --go` does NOT need this.
#
# Generate at: https://expo.dev/settings/access-tokens
# The token is shown only once — save it in the server's .env, never
# commit it, never bake it into the Dockerfile.
EXPO_TOKEN=

# Hostname where the QR-code landing page is served from a browser.
# The container's port 80 (busybox-extras httpd) should be fronted by
# Traefik/Dokploy with TLS pointing at this hostname.
# Example: PUBLIC_HOST=expo.gym.quickfiller.org
PUBLIC_HOST=

# Full URL where Metro is reachable from phones. When set, Metro
# advertises this exact URL as the manifest URL (no :8081 port), via
# EXPO_PACKAGER_PROXY_URL. The QR code encodes it too. The container's
# port 8081 should be fronted by a second Traefik router with TLS
# pointing at this hostname.
#
# Leave empty to fall back to the legacy `exp://${PUBLIC_HOST}:8081`
# URL, which requires port 8081 to be open on the public interface.
#
# Example: METRO_PUBLIC_URL=https://expo.app.gym.quickfiller.org
METRO_PUBLIC_URL=

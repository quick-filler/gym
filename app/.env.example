# Pointed at the local Strapi by default. Override per environment.
# EXPO_PUBLIC_* env vars are inlined into the JS bundle at build time.
EXPO_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:1337/graphql

# The apex domain for the white-label scheme. The app reads the slug
# from a deep link (gymapp://?slug=crossfit-sp) OR from SecureStore.
EXPO_PUBLIC_APP_DOMAIN=gym.app

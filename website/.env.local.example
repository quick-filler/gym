# Data source — `true` to render everything from src/lib/mock-data.ts,
# `false` to call the real Strapi GraphQL API. Defaults to `true` so a
# fresh clone renders the UI without a running backend. Restart the dev
# server after toggling: Next.js inlines NEXT_PUBLIC_* vars at build time.
NEXT_PUBLIC_USE_MOCKS=true

# GraphQL endpoint — the Strapi backend, which serves the only data API.
# Override per environment. Never ship a production build pointing at localhost.
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:1337/graphql

# Marketing canonical origin. Used for metadata (Open Graph, sitemap URLs).
NEXT_PUBLIC_SITE_ORIGIN=http://localhost:3000

# The app domain (student white-label lives under subdomains of this).
NEXT_PUBLIC_APP_DOMAIN=gym.app

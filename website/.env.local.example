# Data source — `false` (default) calls the real Strapi GraphQL API.
# Flip to `true` if you want to render everything from src/lib/mock-data.ts
# instead (useful for UI work on a fresh clone or offline demos).
# Restart the dev server after toggling: Next.js inlines NEXT_PUBLIC_* vars
# at build time.
NEXT_PUBLIC_USE_MOCKS=false

# GraphQL endpoint — the Strapi backend, which serves the only data API.
# Override per environment. Never ship a production build pointing at localhost.
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:7777/graphql

# Marketing canonical origin. Used for metadata (Open Graph, sitemap URLs).
NEXT_PUBLIC_SITE_ORIGIN=http://localhost:9999

# The app domain (student white-label lives under subdomains of this).
NEXT_PUBLIC_APP_DOMAIN=gym.app
